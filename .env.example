# Copy this file to .env and add your Anthropic API key
# Get yours at: https://console.anthropic.com/

ANTHROPIC_API_KEY=sk-ant-...
PORT=3001

# Daily Anthropic spend ceiling (USD) — refuses requests once exceeded
DAILY_SPEND_CAP_USD=10

# Model selection — swap families without code changes
CLAUDE_MODEL_MAIN=claude-opus-4-5
CLAUDE_MODEL_CLASSIFIER=claude-haiku-4-5

# Cookie signing secret (generate a long random string for production)
COOKIE_SECRET=change-me-to-a-long-random-string

# Public URL used in outbound emails (magic links).
# Defaults to http://localhost:PORT when unset.
APP_URL=http://localhost:3001

# SMTP — leave blank in dev to print magic links to stdout
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Brodonam <hello@brodonam.local>

# SQLite path override (defaults to ./data/brodonam.db)
BRODONAM_DB_PATH=

# Structured-log level: debug | info | warn | error | fatal
LOG_LEVEL=info

# Voice companion (optional) — both required for voice mode
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# Admin emails (comma-separated) — required for the clinician approval queue
BRODONAM_ADMIN_EMAILS=

# Postgres URL — when set, swaps the SQLite driver for pg.Pool
# DATABASE_URL=postgres://user:pass@host:5432/brodonam

# Follow-up scheduler (defaults to enabled, 5-min tick)
FOLLOWUPS_ENABLED=1
FOLLOWUP_TICK_MS=300000

# Strict CSP — only enable after extracting inline scripts (see DEPLOY.md)
STRICT_CSP=0
